# Copy this file to .env before the first docker compose run.
# For LAN or public deployment, replace localhost with your real host or domain.

COMPOSE_PROJECT_NAME=microflow

MICROFLOW_BACKEND_PORT=8080
MICROFLOW_FRONTEND_PORT=3000

MICROFLOW_SERVER_ORIGIN=http://localhost:8080
MICROFLOW_API_BASE_URL=http://localhost:8080/api/v1
MICROFLOW_WS_BASE_URL=ws://localhost:8080/ws

MICROFLOW_HTTP_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://127.0.0.1:3000
MICROFLOW_WS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://127.0.0.1:3000

# Replace these with deployment-specific secrets before exposing the service.
MICROFLOW_JWT_SECRET=replace-with-a-long-random-jwt-secret
# Base64-encoded AES key. This example decodes to 32 bytes and should be rotated.
MICROFLOW_CRYPTO_SECRET=ZmVkY2JhOTg3NjU0MzIxMGZlZGNiYTk4NzY1NDMyMTA=

MICROFLOW_SEED_DEMO_ENABLED=false

OPENCLAW_ENDPOINT_URL=
OPENCLAW_CREDENTIAL=
OPENCLAW_AGENT_KEYS=assistant,reviewer
